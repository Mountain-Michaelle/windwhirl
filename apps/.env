# ===================================================================
# WINDWHIRL OMS – Environment Configuration
# ===================================================================
# This file is loaded automatically by python-dotenv.
# All variables listed here override the defaults in settings.py.
# Remove the comment character (#) to enable a variable.

# -------------------------------------------------------------------
# REQUIRED SETTINGS
# -------------------------------------------------------------------
OMS_WHATSAPP_GROUP_NAME="General Order Group"
OMS_WHATSAPP_STAFF_NUMBER="23409029971712"    # 13 digits, no +, no spaces

# -------------------------------------------------------------------
# OPTIONAL SETTINGS (override defaults as needed)
# -------------------------------------------------------------------
# OMS_ENVIRONMENT="production"               # "development" or "production"
# OMS_APP_NAME="Windwhirl OMS"

# --- WhatsApp ---
# OMS_WHATSAPP_MONITOR_NUMBER="2348098765432"  # the number logged in the browser
# OMS_WHATSAPP_POLL_INTERVAL=15

# --- Browser ---
# OMS_BROWSER_HEADLESS=false                 # set to "true" for headless mode
# OMS_BROWSER_SESSION_DIR=".sessions/oms_session"
# OMS_BROWSER_TIMEZONE="Africa/Lagos"

# --- Database ---
# OMS_STORAGE_DATABASE_URL="sqlite:///data/oms.db"
# For PostgreSQL: "postgresql://user:pass@host/oms"

# --- Logging ---
# OMS_LOGGING_LOG_DIR="logs"
# OMS_LOGGING_LOG_LEVEL="INFO"               # DEBUG, INFO, WARNING, ERROR

# --- Observer ---
# OMS_OBSERVER_POLL_INTERVAL=2.0
# OMS_OBSERVER_MAX_AGE_HOURS=24
# OMS_OBSERVER_MAX_MESSAGES=300
# OMS_OBSERVER_MAX_SCROLLS=20
# OMS_OBSERVER_CACHE_SIZE=1000
# OMS_OBSERVER_CHECKPOINT_HISTORY=5

# --- Retry ---
# OMS_RETRY_MAX_RETRIES=3
# OMS_RETRY_DELAY=5.0

# --- Google Sheets (disabled by default) ---
# OMS_GOOGLE_ENABLED=true
# OMS_GOOGLE_CREDENTIALS_FILE="config/google_credentials.json"
# OMS_GOOGLE_SPREADSHEET_ID="your_spreadsheet_id_here"
# OMS_GOOGLE_SHEET_NAME="Orders"
# OMS_GOOGLE_RETRY_LIMIT=5
# OMS_GOOGLE_RETRY_INTERVAL=5.0
# OMS_GOOGLE_BATCH_SIZE=50
# OMS_GOOGLE_QUEUE_MAX_SIZE=500


